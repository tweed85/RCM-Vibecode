{
  "id": "cerner",
  "name": "Cerner (Millennium/Revenue Cycle)",
  "description": "Schema based on Cerner Millennium and Revenue Cycle Management tables",
  "tables": [
    {
      "name": "PERSON",
      "description": "Cerner person/patient master",
      "columns": [
        {"name": "PERSON_ID", "type": "BIGINT", "primary_key": true, "description": "Unique person identifier"},
        {"name": "NAME_FIRST", "type": "VARCHAR(100)", "description": "First name"},
        {"name": "NAME_LAST", "type": "VARCHAR(100)", "description": "Last name"},
        {"name": "NAME_MIDDLE", "type": "VARCHAR(100)", "description": "Middle name"},
        {"name": "BIRTH_DT_TM", "type": "DATETIME", "description": "Date of birth"},
        {"name": "DECEASED_DT_TM", "type": "DATETIME", "description": "Date of death"},
        {"name": "SEX_CD", "type": "BIGINT", "description": "Sex code"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator (1=Active)"}
      ]
    },
    {
      "name": "PERSON_ALIAS",
      "description": "Cerner person identifiers (MRN, SSN, etc.)",
      "columns": [
        {"name": "PERSON_ALIAS_ID", "type": "BIGINT", "primary_key": true, "description": "Alias record ID"},
        {"name": "PERSON_ID", "type": "BIGINT", "foreign_key": "PERSON.PERSON_ID", "description": "Person ID"},
        {"name": "ALIAS", "type": "VARCHAR(50)", "description": "Alias value (MRN, SSN, etc.)"},
        {"name": "ALIAS_POOL_CD", "type": "BIGINT", "description": "Alias type code (MRN, SSN, etc.)"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "ADDRESS",
      "description": "Cerner address records",
      "columns": [
        {"name": "ADDRESS_ID", "type": "BIGINT", "primary_key": true, "description": "Address record ID"},
        {"name": "PARENT_ENTITY_ID", "type": "BIGINT", "description": "Parent entity (person, organization)"},
        {"name": "STREET_ADDR", "type": "VARCHAR(200)", "description": "Street address"},
        {"name": "CITY", "type": "VARCHAR(100)", "description": "City"},
        {"name": "STATE_CD", "type": "BIGINT", "description": "State code"},
        {"name": "ZIPCODE", "type": "VARCHAR(10)", "description": "ZIP code"},
        {"name": "ADDRESS_TYPE_CD", "type": "BIGINT", "description": "Address type (Home, Work, etc.)"}
      ]
    },
    {
      "name": "PRSNL",
      "description": "Cerner personnel/provider master",
      "columns": [
        {"name": "PERSON_ID", "type": "BIGINT", "primary_key": true, "description": "Provider person ID"},
        {"name": "NAME_FULL_FORMATTED", "type": "VARCHAR(200)", "description": "Full formatted name"},
        {"name": "PHYSICIAN_IND", "type": "INT", "description": "Physician indicator"},
        {"name": "POSITION_CD", "type": "BIGINT", "description": "Position code"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "PRSNL_ALIAS",
      "description": "Cerner provider identifiers (NPI, DEA, etc.)",
      "columns": [
        {"name": "PRSNL_ALIAS_ID", "type": "BIGINT", "primary_key": true, "description": "Alias record ID"},
        {"name": "PERSON_ID", "type": "BIGINT", "foreign_key": "PRSNL.PERSON_ID", "description": "Provider person ID"},
        {"name": "ALIAS", "type": "VARCHAR(50)", "description": "Alias value (NPI, DEA, etc.)"},
        {"name": "ALIAS_POOL_CD", "type": "BIGINT", "description": "Alias type code"}
      ]
    },
    {
      "name": "ENCOUNTER",
      "description": "Cerner patient encounter",
      "columns": [
        {"name": "ENCNTR_ID", "type": "BIGINT", "primary_key": true, "description": "Unique encounter identifier"},
        {"name": "PERSON_ID", "type": "BIGINT", "foreign_key": "PERSON.PERSON_ID", "description": "Patient person ID"},
        {"name": "ENCNTR_TYPE_CD", "type": "BIGINT", "description": "Encounter type code"},
        {"name": "ENCNTR_TYPE_CLASS_CD", "type": "BIGINT", "description": "Encounter class (Inpatient, Outpatient, ED, etc.)"},
        {"name": "REG_DT_TM", "type": "DATETIME", "description": "Registration date/time"},
        {"name": "DISCH_DT_TM", "type": "DATETIME", "description": "Discharge date/time"},
        {"name": "ADMIT_TYPE_CD", "type": "BIGINT", "description": "Admit type code"},
        {"name": "LOCATION_CD", "type": "BIGINT", "description": "Location code"},
        {"name": "LOC_FACILITY_CD", "type": "BIGINT", "description": "Facility code"},
        {"name": "FIN_NBR", "type": "VARCHAR(50)", "description": "Financial number (account number)"},
        {"name": "ENCNTR_STATUS_CD", "type": "BIGINT", "description": "Encounter status code"}
      ]
    },
    {
      "name": "ENCNTR_PRSNL_RELTN",
      "description": "Cerner encounter-provider relationship",
      "columns": [
        {"name": "ENCNTR_PRSNL_RELTN_ID", "type": "BIGINT", "primary_key": true, "description": "Relationship record ID"},
        {"name": "ENCNTR_ID", "type": "BIGINT", "foreign_key": "ENCOUNTER.ENCNTR_ID", "description": "Encounter ID"},
        {"name": "PRSNL_PERSON_ID", "type": "BIGINT", "foreign_key": "PRSNL.PERSON_ID", "description": "Provider person ID"},
        {"name": "ENCNTR_PRSNL_R_CD", "type": "BIGINT", "description": "Relationship type (Attending, Admitting, etc.)"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "DIAGNOSIS",
      "description": "Cerner diagnosis records",
      "columns": [
        {"name": "DIAGNOSIS_ID", "type": "BIGINT", "primary_key": true, "description": "Diagnosis record ID"},
        {"name": "ENCNTR_ID", "type": "BIGINT", "foreign_key": "ENCOUNTER.ENCNTR_ID", "description": "Encounter ID"},
        {"name": "NOMENCLATURE_ID", "type": "BIGINT", "foreign_key": "NOMENCLATURE.NOMENCLATURE_ID", "description": "Nomenclature ID"},
        {"name": "DIAG_TYPE_CD", "type": "BIGINT", "description": "Diagnosis type (Admitting, Final, etc.)"},
        {"name": "DIAG_PRIORITY", "type": "INT", "description": "Diagnosis priority (1=Primary)"},
        {"name": "RANKING_CD", "type": "BIGINT", "description": "Ranking code"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "NOMENCLATURE",
      "description": "Cerner nomenclature/code master",
      "columns": [
        {"name": "NOMENCLATURE_ID", "type": "BIGINT", "primary_key": true, "description": "Nomenclature ID"},
        {"name": "SOURCE_IDENTIFIER", "type": "VARCHAR(50)", "description": "Source code (ICD-10, CPT, etc.)"},
        {"name": "SOURCE_STRING", "type": "VARCHAR(500)", "description": "Code description"},
        {"name": "SOURCE_VOCABULARY_CD", "type": "BIGINT", "description": "Vocabulary (ICD10, CPT4, HCPCS)"}
      ]
    },
    {
      "name": "HEALTH_PLAN",
      "description": "Cerner health plan master",
      "columns": [
        {"name": "HEALTH_PLAN_ID", "type": "BIGINT", "primary_key": true, "description": "Health plan ID"},
        {"name": "PLAN_NAME", "type": "VARCHAR(100)", "description": "Plan name"},
        {"name": "PLAN_TYPE_CD", "type": "BIGINT", "description": "Plan type code"},
        {"name": "FINANCIAL_CLASS_CD", "type": "BIGINT", "description": "Financial class"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "ENCNTR_PLAN_RELTN",
      "description": "Cerner encounter insurance coverage",
      "columns": [
        {"name": "ENCNTR_PLAN_RELTN_ID", "type": "BIGINT", "primary_key": true, "description": "Coverage record ID"},
        {"name": "ENCNTR_ID", "type": "BIGINT", "foreign_key": "ENCOUNTER.ENCNTR_ID", "description": "Encounter ID"},
        {"name": "HEALTH_PLAN_ID", "type": "BIGINT", "foreign_key": "HEALTH_PLAN.HEALTH_PLAN_ID", "description": "Health plan ID"},
        {"name": "PERSON_PLAN_RELTN_ID", "type": "BIGINT", "description": "Person plan relation ID"},
        {"name": "PRIORITY_SEQ", "type": "INT", "description": "Priority sequence (1=Primary)"},
        {"name": "MEMBER_NBR", "type": "VARCHAR(50)", "description": "Member number"},
        {"name": "GROUP_NBR", "type": "VARCHAR(50)", "description": "Group number"},
        {"name": "BEG_EFFECTIVE_DT_TM", "type": "DATETIME", "description": "Coverage begin date"},
        {"name": "END_EFFECTIVE_DT_TM", "type": "DATETIME", "description": "Coverage end date"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "CHARGE",
      "description": "Cerner charge/billing records",
      "columns": [
        {"name": "CHARGE_ID", "type": "BIGINT", "primary_key": true, "description": "Charge record ID"},
        {"name": "ENCNTR_ID", "type": "BIGINT", "foreign_key": "ENCOUNTER.ENCNTR_ID", "description": "Encounter ID"},
        {"name": "BILL_ITEM_ID", "type": "BIGINT", "foreign_key": "BILL_ITEM.BILL_ITEM_ID", "description": "Bill item ID"},
        {"name": "CHARGE_TYPE_CD", "type": "BIGINT", "description": "Charge type code"},
        {"name": "ITEM_QUANTITY", "type": "INT", "description": "Quantity"},
        {"name": "PRICE", "type": "DECIMAL(18,2)", "description": "Unit price"},
        {"name": "CHARGE_AMOUNT", "type": "DECIMAL(18,2)", "description": "Total charge amount"},
        {"name": "SERVICE_DT_TM", "type": "DATETIME", "description": "Service date/time"},
        {"name": "POST_DT_TM", "type": "DATETIME", "description": "Posted date/time"},
        {"name": "CHARGE_STATUS_CD", "type": "BIGINT", "description": "Charge status"}
      ]
    },
    {
      "name": "BILL_ITEM",
      "description": "Cerner billable item master",
      "columns": [
        {"name": "BILL_ITEM_ID", "type": "BIGINT", "primary_key": true, "description": "Bill item ID"},
        {"name": "DESCRIPTION", "type": "VARCHAR(200)", "description": "Item description"},
        {"name": "CPT_CD", "type": "VARCHAR(10)", "description": "CPT code"},
        {"name": "HCPCS_CD", "type": "VARCHAR(10)", "description": "HCPCS code"},
        {"name": "REVENUE_CODE", "type": "VARCHAR(10)", "description": "Revenue code"},
        {"name": "ACTIVE_IND", "type": "INT", "description": "Active indicator"}
      ]
    },
    {
      "name": "CLAIM",
      "description": "Cerner claim header",
      "columns": [
        {"name": "CLAIM_ID", "type": "BIGINT", "primary_key": true, "description": "Claim ID"},
        {"name": "ENCNTR_ID", "type": "BIGINT", "foreign_key": "ENCOUNTER.ENCNTR_ID", "description": "Encounter ID"},
        {"name": "PERSON_ID", "type": "BIGINT", "foreign_key": "PERSON.PERSON_ID", "description": "Patient person ID"},
        {"name": "HEALTH_PLAN_ID", "type": "BIGINT", "foreign_key": "HEALTH_PLAN.HEALTH_PLAN_ID", "description": "Health plan ID"},
        {"name": "CLAIM_TYPE_CD", "type": "BIGINT", "description": "Claim type (Professional, Institutional)"},
        {"name": "CLAIM_STATUS_CD", "type": "BIGINT", "description": "Claim status"},
        {"name": "SUBMIT_DT_TM", "type": "DATETIME", "description": "Submission date"},
        {"name": "TOTAL_CHARGE", "type": "DECIMAL(18,2)", "description": "Total charges"},
        {"name": "TOTAL_ALLOWED", "type": "DECIMAL(18,2)", "description": "Total allowed"},
        {"name": "TOTAL_PAID", "type": "DECIMAL(18,2)", "description": "Total paid"},
        {"name": "PATIENT_RESP", "type": "DECIMAL(18,2)", "description": "Patient responsibility"},
        {"name": "DENIAL_REASON_CD", "type": "BIGINT", "description": "Denial reason code"},
        {"name": "CREATE_DT_TM", "type": "DATETIME", "description": "Created date"},
        {"name": "UPDT_DT_TM", "type": "DATETIME", "description": "Updated date"}
      ]
    },
    {
      "name": "CLAIM_LINE",
      "description": "Cerner claim line detail",
      "columns": [
        {"name": "CLAIM_LINE_ID", "type": "BIGINT", "primary_key": true, "description": "Claim line ID"},
        {"name": "CLAIM_ID", "type": "BIGINT", "foreign_key": "CLAIM.CLAIM_ID", "description": "Claim ID"},
        {"name": "CHARGE_ID", "type": "BIGINT", "foreign_key": "CHARGE.CHARGE_ID", "description": "Charge ID"},
        {"name": "LINE_NBR", "type": "INT", "description": "Line number"},
        {"name": "SERVICE_DT_TM", "type": "DATETIME", "description": "Service date"},
        {"name": "CPT_CD", "type": "VARCHAR(10)", "description": "CPT code"},
        {"name": "MODIFIER_1", "type": "VARCHAR(2)", "description": "Modifier 1"},
        {"name": "MODIFIER_2", "type": "VARCHAR(2)", "description": "Modifier 2"},
        {"name": "UNITS", "type": "INT", "description": "Units"},
        {"name": "LINE_CHARGE", "type": "DECIMAL(18,2)", "description": "Line charges"},
        {"name": "LINE_ALLOWED", "type": "DECIMAL(18,2)", "description": "Line allowed"},
        {"name": "LINE_PAID", "type": "DECIMAL(18,2)", "description": "Line paid"},
        {"name": "LINE_STATUS_CD", "type": "BIGINT", "description": "Line status"}
      ]
    },
    {
      "name": "PAYMENT",
      "description": "Cerner payment records",
      "columns": [
        {"name": "PAYMENT_ID", "type": "BIGINT", "primary_key": true, "description": "Payment ID"},
        {"name": "CLAIM_ID", "type": "BIGINT", "foreign_key": "CLAIM.CLAIM_ID", "description": "Claim ID"},
        {"name": "PAYMENT_TYPE_CD", "type": "BIGINT", "description": "Payment type (Insurance, Patient, Adjustment)"},
        {"name": "PAYMENT_METHOD_CD", "type": "BIGINT", "description": "Payment method (Check, EFT, Cash, CC)"},
        {"name": "AMOUNT", "type": "DECIMAL(18,2)", "description": "Payment amount"},
        {"name": "PAYMENT_DT_TM", "type": "DATETIME", "description": "Payment date"},
        {"name": "POST_DT_TM", "type": "DATETIME", "description": "Posted date"},
        {"name": "CHECK_NBR", "type": "VARCHAR(50)", "description": "Check/EFT number"},
        {"name": "PAYER_NAME", "type": "VARCHAR(100)", "description": "Payer name"}
      ]
    },
    {
      "name": "STATEMENT",
      "description": "Cerner patient statement",
      "columns": [
        {"name": "STATEMENT_ID", "type": "BIGINT", "primary_key": true, "description": "Statement ID"},
        {"name": "PERSON_ID", "type": "BIGINT", "foreign_key": "PERSON.PERSON_ID", "description": "Patient person ID"},
        {"name": "STATEMENT_DT_TM", "type": "DATETIME", "description": "Statement date"},
        {"name": "DUE_DT_TM", "type": "DATETIME", "description": "Due date"},
        {"name": "AMOUNT_DUE", "type": "DECIMAL(18,2)", "description": "Amount due"},
        {"name": "PREV_BAL", "type": "DECIMAL(18,2)", "description": "Previous balance"},
        {"name": "NEW_CHARGES", "type": "DECIMAL(18,2)", "description": "New charges"},
        {"name": "PAYMENTS", "type": "DECIMAL(18,2)", "description": "Payments received"},
        {"name": "AGING_CURRENT", "type": "DECIMAL(18,2)", "description": "Current (0-30)"},
        {"name": "AGING_30", "type": "DECIMAL(18,2)", "description": "31-60 days"},
        {"name": "AGING_60", "type": "DECIMAL(18,2)", "description": "61-90 days"},
        {"name": "AGING_90_PLUS", "type": "DECIMAL(18,2)", "description": "Over 90 days"},
        {"name": "STATEMENT_STATUS_CD", "type": "BIGINT", "description": "Statement status"}
      ]
    }
  ]
}
