{
  "id": "epic",
  "name": "Epic (Clarity/Caboodle)",
  "description": "Schema based on Epic's Clarity data warehouse and Resolute billing tables",
  "tables": [
    {
      "name": "PATIENT",
      "description": "Epic patient master record (Clarity PAT table)",
      "columns": [
        {"name": "PAT_ID", "type": "VARCHAR(18)", "primary_key": true, "description": "Unique patient identifier"},
        {"name": "PAT_MRN_ID", "type": "VARCHAR(50)", "description": "Medical record number"},
        {"name": "PAT_FIRST_NAME", "type": "VARCHAR(100)", "description": "Patient first name"},
        {"name": "PAT_LAST_NAME", "type": "VARCHAR(100)", "description": "Patient last name"},
        {"name": "BIRTH_DATE", "type": "DATE", "description": "Patient date of birth"},
        {"name": "SSN", "type": "VARCHAR(11)", "description": "Social security number"},
        {"name": "ADD_LINE_1", "type": "VARCHAR(100)", "description": "Address line 1"},
        {"name": "CITY", "type": "VARCHAR(50)", "description": "City"},
        {"name": "STATE_C", "type": "VARCHAR(2)", "description": "State code"},
        {"name": "ZIP", "type": "VARCHAR(10)", "description": "ZIP code"},
        {"name": "HOME_PHONE", "type": "VARCHAR(20)", "description": "Home phone"},
        {"name": "EMAIL_ADDRESS", "type": "VARCHAR(100)", "description": "Email address"},
        {"name": "CUR_PCP_PROV_ID", "type": "VARCHAR(18)", "foreign_key": "CLARITY_SER.PROV_ID", "description": "Current PCP provider ID"}
      ]
    },
    {
      "name": "CLARITY_SER",
      "description": "Epic provider/physician master (Service provider table)",
      "columns": [
        {"name": "PROV_ID", "type": "VARCHAR(18)", "primary_key": true, "description": "Unique provider identifier"},
        {"name": "PROV_NAME", "type": "VARCHAR(200)", "description": "Provider full name"},
        {"name": "NPI", "type": "VARCHAR(10)", "description": "National Provider Identifier"},
        {"name": "SPECIALTY", "type": "VARCHAR(100)", "description": "Provider specialty"},
        {"name": "DEPARTMENT_ID", "type": "VARCHAR(18)", "foreign_key": "CLARITY_DEP.DEPARTMENT_ID", "description": "Department ID"},
        {"name": "ACTIVE_STATUS_C", "type": "INT", "description": "Active status (1=Active, 2=Inactive)"}
      ]
    },
    {
      "name": "CLARITY_DEP",
      "description": "Epic department master",
      "columns": [
        {"name": "DEPARTMENT_ID", "type": "VARCHAR(18)", "primary_key": true, "description": "Unique department identifier"},
        {"name": "DEPARTMENT_NAME", "type": "VARCHAR(100)", "description": "Department name"},
        {"name": "SPECIALTY", "type": "VARCHAR(100)", "description": "Department specialty"},
        {"name": "REV_LOC_ID", "type": "VARCHAR(18)", "description": "Revenue location ID"},
        {"name": "SERVICE_AREA_ID", "type": "VARCHAR(18)", "description": "Service area ID"}
      ]
    },
    {
      "name": "PAT_ENC",
      "description": "Epic patient encounter record",
      "columns": [
        {"name": "PAT_ENC_CSN_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Contact serial number (unique encounter ID)"},
        {"name": "PAT_ID", "type": "VARCHAR(18)", "foreign_key": "PATIENT.PAT_ID", "description": "Patient ID"},
        {"name": "VISIT_PROV_ID", "type": "VARCHAR(18)", "foreign_key": "CLARITY_SER.PROV_ID", "description": "Visit provider ID"},
        {"name": "DEPARTMENT_ID", "type": "VARCHAR(18)", "foreign_key": "CLARITY_DEP.DEPARTMENT_ID", "description": "Department ID"},
        {"name": "CONTACT_DATE", "type": "DATE", "description": "Encounter date"},
        {"name": "ENC_TYPE_C", "type": "INT", "description": "Encounter type category"},
        {"name": "ENC_TYPE_TITLE", "type": "VARCHAR(50)", "description": "Encounter type name"},
        {"name": "APPT_STATUS_C", "type": "INT", "description": "Appointment status"},
        {"name": "ENC_CLOSED_YN", "type": "VARCHAR(1)", "description": "Encounter closed flag (Y/N)"}
      ]
    },
    {
      "name": "COVERAGE",
      "description": "Epic patient insurance coverage",
      "columns": [
        {"name": "COVERAGE_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Unique coverage identifier"},
        {"name": "PAT_ID", "type": "VARCHAR(18)", "foreign_key": "PATIENT.PAT_ID", "description": "Patient ID"},
        {"name": "PAYOR_ID", "type": "DECIMAL(18)", "foreign_key": "CLARITY_EPM.PAYOR_ID", "description": "Payor ID"},
        {"name": "PLAN_ID", "type": "DECIMAL(18)", "foreign_key": "CLARITY_EPP.BENEFIT_PLAN_ID", "description": "Benefit plan ID"},
        {"name": "SUBSCR_NUM", "type": "VARCHAR(50)", "description": "Subscriber/member number"},
        {"name": "GROUP_NUM", "type": "VARCHAR(50)", "description": "Group number"},
        {"name": "CVG_TYPE_C", "type": "INT", "description": "Coverage type (1=Primary, 2=Secondary, 3=Tertiary)"},
        {"name": "EFF_DATE", "type": "DATE", "description": "Effective date"},
        {"name": "TERM_DATE", "type": "DATE", "description": "Termination date"}
      ]
    },
    {
      "name": "CLARITY_EPM",
      "description": "Epic payor master",
      "columns": [
        {"name": "PAYOR_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Unique payor identifier"},
        {"name": "PAYOR_NAME", "type": "VARCHAR(100)", "description": "Payor name"},
        {"name": "FINANCIAL_CLASS_C", "type": "INT", "description": "Financial class category"},
        {"name": "FINANCIAL_CLASS", "type": "VARCHAR(50)", "description": "Financial class name (Commercial, Medicare, Medicaid, etc.)"}
      ]
    },
    {
      "name": "CLARITY_EPP",
      "description": "Epic benefit plan master",
      "columns": [
        {"name": "BENEFIT_PLAN_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Unique benefit plan identifier"},
        {"name": "BENEFIT_PLAN_NAME", "type": "VARCHAR(100)", "description": "Benefit plan name"},
        {"name": "PAYOR_ID", "type": "DECIMAL(18)", "foreign_key": "CLARITY_EPM.PAYOR_ID", "description": "Payor ID"},
        {"name": "PLAN_TYPE_C", "type": "INT", "description": "Plan type category (HMO, PPO, etc.)"}
      ]
    },
    {
      "name": "HSP_ACCOUNT",
      "description": "Epic hospital account (billing account)",
      "columns": [
        {"name": "HSP_ACCOUNT_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Unique hospital account ID"},
        {"name": "PAT_ID", "type": "VARCHAR(18)", "foreign_key": "PATIENT.PAT_ID", "description": "Patient ID"},
        {"name": "PAT_ENC_CSN_ID", "type": "DECIMAL(18)", "foreign_key": "PAT_ENC.PAT_ENC_CSN_ID", "description": "Encounter CSN"},
        {"name": "ACCT_BASECLS_HA_C", "type": "INT", "description": "Account base class (Inpatient, Outpatient, etc.)"},
        {"name": "PRIM_CVG_ID", "type": "DECIMAL(18)", "foreign_key": "COVERAGE.COVERAGE_ID", "description": "Primary coverage ID"},
        {"name": "ADM_DATE_TIME", "type": "DATETIME", "description": "Admission date/time"},
        {"name": "DISCH_DATE_TIME", "type": "DATETIME", "description": "Discharge date/time"},
        {"name": "TOT_CHGS", "type": "DECIMAL(18,2)", "description": "Total charges"},
        {"name": "TOT_PMTS", "type": "DECIMAL(18,2)", "description": "Total payments"},
        {"name": "TOT_ADJS", "type": "DECIMAL(18,2)", "description": "Total adjustments"},
        {"name": "ACCT_BALANCE", "type": "DECIMAL(18,2)", "description": "Account balance"}
      ]
    },
    {
      "name": "HSP_TRANSACTIONS",
      "description": "Epic hospital account transactions",
      "columns": [
        {"name": "TX_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Transaction ID"},
        {"name": "HSP_ACCOUNT_ID", "type": "DECIMAL(18)", "foreign_key": "HSP_ACCOUNT.HSP_ACCOUNT_ID", "description": "Hospital account ID"},
        {"name": "TX_TYPE_HA_C", "type": "INT", "description": "Transaction type (1=Charge, 2=Payment, 3=Adjustment)"},
        {"name": "PROC_ID", "type": "DECIMAL(18)", "foreign_key": "CLARITY_EAP.PROC_ID", "description": "Procedure ID"},
        {"name": "CPT_CODE", "type": "VARCHAR(10)", "description": "CPT code"},
        {"name": "TX_AMOUNT", "type": "DECIMAL(18,2)", "description": "Transaction amount"},
        {"name": "TX_POST_DATE", "type": "DATE", "description": "Transaction post date"},
        {"name": "SERVICE_DATE", "type": "DATE", "description": "Service date"}
      ]
    },
    {
      "name": "CLARITY_EAP",
      "description": "Epic procedure master",
      "columns": [
        {"name": "PROC_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Procedure ID"},
        {"name": "PROC_CODE", "type": "VARCHAR(20)", "description": "Procedure code"},
        {"name": "PROC_NAME", "type": "VARCHAR(200)", "description": "Procedure name"},
        {"name": "CPT_CODE", "type": "VARCHAR(10)", "description": "CPT code"},
        {"name": "PROC_CAT_C", "type": "INT", "description": "Procedure category"}
      ]
    },
    {
      "name": "CLM_VALUES",
      "description": "Epic professional billing claims",
      "columns": [
        {"name": "CLAIM_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Unique claim identifier"},
        {"name": "PAT_ID", "type": "VARCHAR(18)", "foreign_key": "PATIENT.PAT_ID", "description": "Patient ID"},
        {"name": "PAT_ENC_CSN_ID", "type": "DECIMAL(18)", "foreign_key": "PAT_ENC.PAT_ENC_CSN_ID", "description": "Encounter CSN"},
        {"name": "COVERAGE_ID", "type": "DECIMAL(18)", "foreign_key": "COVERAGE.COVERAGE_ID", "description": "Coverage ID"},
        {"name": "CLAIM_STATUS_C", "type": "INT", "description": "Claim status (1=New, 2=Submitted, 3=Denied, 4=Paid)"},
        {"name": "SUBMIT_DATE", "type": "DATE", "description": "Claim submission date"},
        {"name": "TOT_CLAIM_CHGS", "type": "DECIMAL(18,2)", "description": "Total claim charges"},
        {"name": "TOT_CLAIM_ALLOWED", "type": "DECIMAL(18,2)", "description": "Total allowed amount"},
        {"name": "TOT_CLAIM_PMTS", "type": "DECIMAL(18,2)", "description": "Total claim payments"},
        {"name": "DENIAL_REASON_C", "type": "INT", "description": "Denial reason category"},
        {"name": "DENIAL_REASON", "type": "VARCHAR(255)", "description": "Denial reason description"}
      ]
    },
    {
      "name": "HSP_CLM_DETAIL",
      "description": "Epic claim line details",
      "columns": [
        {"name": "CLM_LINE_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Claim line ID"},
        {"name": "CLAIM_ID", "type": "DECIMAL(18)", "foreign_key": "CLM_VALUES.CLAIM_ID", "description": "Claim ID"},
        {"name": "LINE_NUM", "type": "INT", "description": "Line number"},
        {"name": "CPT_CODE", "type": "VARCHAR(10)", "description": "CPT code"},
        {"name": "MODS", "type": "VARCHAR(20)", "description": "Modifiers"},
        {"name": "UNITS", "type": "INT", "description": "Units"},
        {"name": "LINE_CHGS", "type": "DECIMAL(18,2)", "description": "Line charges"},
        {"name": "LINE_ALLOWED", "type": "DECIMAL(18,2)", "description": "Line allowed amount"},
        {"name": "LINE_PMTS", "type": "DECIMAL(18,2)", "description": "Line payments"}
      ]
    },
    {
      "name": "HSP_ACCT_DX_LIST",
      "description": "Epic account diagnosis list",
      "columns": [
        {"name": "HSP_ACCOUNT_ID", "type": "DECIMAL(18)", "foreign_key": "HSP_ACCOUNT.HSP_ACCOUNT_ID", "description": "Hospital account ID"},
        {"name": "LINE", "type": "INT", "description": "Diagnosis sequence"},
        {"name": "DX_ID", "type": "DECIMAL(18)", "foreign_key": "CLARITY_EDG.DX_ID", "description": "Diagnosis ID"},
        {"name": "PRIMARY_DX_YN", "type": "VARCHAR(1)", "description": "Primary diagnosis flag"}
      ]
    },
    {
      "name": "CLARITY_EDG",
      "description": "Epic diagnosis master",
      "columns": [
        {"name": "DX_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Diagnosis ID"},
        {"name": "DX_NAME", "type": "VARCHAR(200)", "description": "Diagnosis name"},
        {"name": "CURRENT_ICD10_LIST", "type": "VARCHAR(10)", "description": "ICD-10 code"},
        {"name": "CURRENT_ICD9_LIST", "type": "VARCHAR(10)", "description": "ICD-9 code"}
      ]
    },
    {
      "name": "ARPB_TRANSACTIONS",
      "description": "Epic professional billing AR transactions",
      "columns": [
        {"name": "TX_ID", "type": "DECIMAL(18)", "primary_key": true, "description": "Transaction ID"},
        {"name": "CLAIM_ID", "type": "DECIMAL(18)", "foreign_key": "CLM_VALUES.CLAIM_ID", "description": "Claim ID"},
        {"name": "TX_TYPE_C", "type": "INT", "description": "Transaction type"},
        {"name": "AMOUNT", "type": "DECIMAL(18,2)", "description": "Transaction amount"},
        {"name": "POST_DATE", "type": "DATE", "description": "Post date"},
        {"name": "PAYOR_ID", "type": "DECIMAL(18)", "foreign_key": "CLARITY_EPM.PAYOR_ID", "description": "Payor ID"},
        {"name": "CHECK_NUM", "type": "VARCHAR(50)", "description": "Check/EFT number"}
      ]
    }
  ]
}
