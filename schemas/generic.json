{
  "id": "generic",
  "name": "Generic RCM Schema",
  "description": "A generic revenue cycle management schema with standard table naming conventions",
  "tables": [
    {
      "name": "patients",
      "description": "Patient demographic and contact information",
      "columns": [
        {"name": "patient_id", "type": "INT", "primary_key": true, "description": "Unique patient identifier"},
        {"name": "first_name", "type": "VARCHAR(100)", "description": "Patient first name"},
        {"name": "last_name", "type": "VARCHAR(100)", "description": "Patient last name"},
        {"name": "date_of_birth", "type": "DATE", "description": "Patient date of birth"},
        {"name": "ssn", "type": "VARCHAR(11)", "description": "Social security number (encrypted)"},
        {"name": "address", "type": "VARCHAR(255)", "description": "Street address"},
        {"name": "city", "type": "VARCHAR(100)", "description": "City"},
        {"name": "state", "type": "VARCHAR(2)", "description": "State code"},
        {"name": "zip_code", "type": "VARCHAR(10)", "description": "ZIP code"},
        {"name": "phone", "type": "VARCHAR(20)", "description": "Primary phone number"},
        {"name": "email", "type": "VARCHAR(255)", "description": "Email address"},
        {"name": "created_at", "type": "TIMESTAMP", "description": "Record creation timestamp"}
      ]
    },
    {
      "name": "insurance_plans",
      "description": "Insurance plan and payer information",
      "columns": [
        {"name": "plan_id", "type": "INT", "primary_key": true, "description": "Unique plan identifier"},
        {"name": "payer_name", "type": "VARCHAR(200)", "description": "Insurance company name"},
        {"name": "plan_name", "type": "VARCHAR(200)", "description": "Specific plan name"},
        {"name": "plan_type", "type": "VARCHAR(50)", "description": "Plan type (HMO, PPO, Medicare, Medicaid, etc.)"},
        {"name": "payer_id", "type": "VARCHAR(50)", "description": "Payer ID for electronic submissions"},
        {"name": "contact_phone", "type": "VARCHAR(20)", "description": "Payer contact phone"},
        {"name": "is_active", "type": "BOOLEAN", "description": "Whether plan is currently active"}
      ]
    },
    {
      "name": "patient_insurance",
      "description": "Patient insurance coverage assignments",
      "columns": [
        {"name": "coverage_id", "type": "INT", "primary_key": true, "description": "Unique coverage record ID"},
        {"name": "patient_id", "type": "INT", "foreign_key": "patients.patient_id", "description": "Reference to patient"},
        {"name": "plan_id", "type": "INT", "foreign_key": "insurance_plans.plan_id", "description": "Reference to insurance plan"},
        {"name": "member_id", "type": "VARCHAR(50)", "description": "Member/subscriber ID"},
        {"name": "group_number", "type": "VARCHAR(50)", "description": "Group number"},
        {"name": "coverage_type", "type": "VARCHAR(20)", "description": "Primary, Secondary, or Tertiary"},
        {"name": "effective_date", "type": "DATE", "description": "Coverage start date"},
        {"name": "termination_date", "type": "DATE", "description": "Coverage end date (null if active)"},
        {"name": "copay_amount", "type": "DECIMAL(10,2)", "description": "Standard copay amount"},
        {"name": "deductible_amount", "type": "DECIMAL(10,2)", "description": "Annual deductible"},
        {"name": "deductible_met", "type": "DECIMAL(10,2)", "description": "Deductible amount met YTD"}
      ]
    },
    {
      "name": "providers",
      "description": "Healthcare providers and physicians",
      "columns": [
        {"name": "provider_id", "type": "INT", "primary_key": true, "description": "Unique provider identifier"},
        {"name": "npi", "type": "VARCHAR(10)", "description": "National Provider Identifier"},
        {"name": "first_name", "type": "VARCHAR(100)", "description": "Provider first name"},
        {"name": "last_name", "type": "VARCHAR(100)", "description": "Provider last name"},
        {"name": "specialty", "type": "VARCHAR(100)", "description": "Medical specialty"},
        {"name": "department", "type": "VARCHAR(100)", "description": "Department"},
        {"name": "is_active", "type": "BOOLEAN", "description": "Whether provider is currently active"}
      ]
    },
    {
      "name": "encounters",
      "description": "Patient visits and encounters",
      "columns": [
        {"name": "encounter_id", "type": "INT", "primary_key": true, "description": "Unique encounter identifier"},
        {"name": "patient_id", "type": "INT", "foreign_key": "patients.patient_id", "description": "Reference to patient"},
        {"name": "provider_id", "type": "INT", "foreign_key": "providers.provider_id", "description": "Rendering provider"},
        {"name": "encounter_date", "type": "DATE", "description": "Date of service"},
        {"name": "encounter_type", "type": "VARCHAR(50)", "description": "Type (Office Visit, ER, Inpatient, etc.)"},
        {"name": "facility_code", "type": "VARCHAR(20)", "description": "Place of service code"},
        {"name": "chief_complaint", "type": "TEXT", "description": "Reason for visit"},
        {"name": "status", "type": "VARCHAR(30)", "description": "Encounter status (Open, Closed, Billed)"}
      ]
    },
    {
      "name": "diagnoses",
      "description": "Diagnosis codes assigned to encounters",
      "columns": [
        {"name": "diagnosis_id", "type": "INT", "primary_key": true, "description": "Unique diagnosis record ID"},
        {"name": "encounter_id", "type": "INT", "foreign_key": "encounters.encounter_id", "description": "Reference to encounter"},
        {"name": "icd10_code", "type": "VARCHAR(10)", "description": "ICD-10 diagnosis code"},
        {"name": "description", "type": "VARCHAR(255)", "description": "Diagnosis description"},
        {"name": "sequence", "type": "INT", "description": "Diagnosis sequence (1=primary)"},
        {"name": "is_primary", "type": "BOOLEAN", "description": "Whether this is the primary diagnosis"}
      ]
    },
    {
      "name": "procedures",
      "description": "Procedure codes and charges",
      "columns": [
        {"name": "procedure_id", "type": "INT", "primary_key": true, "description": "Unique procedure record ID"},
        {"name": "encounter_id", "type": "INT", "foreign_key": "encounters.encounter_id", "description": "Reference to encounter"},
        {"name": "cpt_code", "type": "VARCHAR(10)", "description": "CPT/HCPCS procedure code"},
        {"name": "description", "type": "VARCHAR(255)", "description": "Procedure description"},
        {"name": "modifier1", "type": "VARCHAR(2)", "description": "First modifier"},
        {"name": "modifier2", "type": "VARCHAR(2)", "description": "Second modifier"},
        {"name": "units", "type": "INT", "description": "Number of units"},
        {"name": "charge_amount", "type": "DECIMAL(10,2)", "description": "Billed charge amount"},
        {"name": "service_date", "type": "DATE", "description": "Date service was performed"}
      ]
    },
    {
      "name": "claims",
      "description": "Insurance claims submitted for payment",
      "columns": [
        {"name": "claim_id", "type": "INT", "primary_key": true, "description": "Unique claim identifier"},
        {"name": "encounter_id", "type": "INT", "foreign_key": "encounters.encounter_id", "description": "Reference to encounter"},
        {"name": "patient_id", "type": "INT", "foreign_key": "patients.patient_id", "description": "Reference to patient"},
        {"name": "coverage_id", "type": "INT", "foreign_key": "patient_insurance.coverage_id", "description": "Insurance coverage used"},
        {"name": "claim_number", "type": "VARCHAR(50)", "description": "External claim reference number"},
        {"name": "claim_type", "type": "VARCHAR(20)", "description": "Professional or Institutional"},
        {"name": "submission_date", "type": "DATE", "description": "Date claim was submitted"},
        {"name": "total_charge", "type": "DECIMAL(12,2)", "description": "Total billed amount"},
        {"name": "total_allowed", "type": "DECIMAL(12,2)", "description": "Total allowed amount"},
        {"name": "total_paid", "type": "DECIMAL(12,2)", "description": "Total amount paid"},
        {"name": "patient_responsibility", "type": "DECIMAL(12,2)", "description": "Amount patient owes"},
        {"name": "status", "type": "VARCHAR(30)", "description": "Claim status (Submitted, Pending, Paid, Denied, etc.)"},
        {"name": "denial_reason", "type": "VARCHAR(255)", "description": "Reason for denial if applicable"},
        {"name": "denial_code", "type": "VARCHAR(20)", "description": "Denial reason code"},
        {"name": "created_at", "type": "TIMESTAMP", "description": "Record creation timestamp"},
        {"name": "updated_at", "type": "TIMESTAMP", "description": "Last update timestamp"}
      ]
    },
    {
      "name": "claim_lines",
      "description": "Individual line items on claims",
      "columns": [
        {"name": "line_id", "type": "INT", "primary_key": true, "description": "Unique line item ID"},
        {"name": "claim_id", "type": "INT", "foreign_key": "claims.claim_id", "description": "Reference to claim"},
        {"name": "procedure_id", "type": "INT", "foreign_key": "procedures.procedure_id", "description": "Reference to procedure"},
        {"name": "line_number", "type": "INT", "description": "Line sequence number"},
        {"name": "cpt_code", "type": "VARCHAR(10)", "description": "CPT/HCPCS code billed"},
        {"name": "units", "type": "INT", "description": "Units billed"},
        {"name": "charge_amount", "type": "DECIMAL(10,2)", "description": "Line charge amount"},
        {"name": "allowed_amount", "type": "DECIMAL(10,2)", "description": "Allowed amount"},
        {"name": "paid_amount", "type": "DECIMAL(10,2)", "description": "Amount paid"},
        {"name": "adjustment_amount", "type": "DECIMAL(10,2)", "description": "Contractual adjustment"},
        {"name": "status", "type": "VARCHAR(30)", "description": "Line status"}
      ]
    },
    {
      "name": "payments",
      "description": "Payment transactions received",
      "columns": [
        {"name": "payment_id", "type": "INT", "primary_key": true, "description": "Unique payment identifier"},
        {"name": "claim_id", "type": "INT", "foreign_key": "claims.claim_id", "description": "Reference to claim"},
        {"name": "payment_date", "type": "DATE", "description": "Date payment received"},
        {"name": "payment_amount", "type": "DECIMAL(12,2)", "description": "Payment amount"},
        {"name": "payment_type", "type": "VARCHAR(30)", "description": "Insurance, Patient, or Adjustment"},
        {"name": "payment_method", "type": "VARCHAR(30)", "description": "Check, EFT, Credit Card, Cash"},
        {"name": "check_number", "type": "VARCHAR(50)", "description": "Check or EFT reference number"},
        {"name": "payer_name", "type": "VARCHAR(200)", "description": "Name of payer"},
        {"name": "posted_date", "type": "DATE", "description": "Date payment was posted"}
      ]
    },
    {
      "name": "patient_statements",
      "description": "Patient billing statements",
      "columns": [
        {"name": "statement_id", "type": "INT", "primary_key": true, "description": "Unique statement ID"},
        {"name": "patient_id", "type": "INT", "foreign_key": "patients.patient_id", "description": "Reference to patient"},
        {"name": "statement_date", "type": "DATE", "description": "Date statement generated"},
        {"name": "due_date", "type": "DATE", "description": "Payment due date"},
        {"name": "amount_due", "type": "DECIMAL(12,2)", "description": "Total amount due"},
        {"name": "previous_balance", "type": "DECIMAL(12,2)", "description": "Previous balance"},
        {"name": "new_charges", "type": "DECIMAL(12,2)", "description": "New charges this period"},
        {"name": "payments_received", "type": "DECIMAL(12,2)", "description": "Payments since last statement"},
        {"name": "aging_current", "type": "DECIMAL(12,2)", "description": "Current (0-30 days)"},
        {"name": "aging_31_60", "type": "DECIMAL(12,2)", "description": "31-60 days"},
        {"name": "aging_61_90", "type": "DECIMAL(12,2)", "description": "61-90 days"},
        {"name": "aging_over_90", "type": "DECIMAL(12,2)", "description": "Over 90 days"},
        {"name": "status", "type": "VARCHAR(30)", "description": "Statement status (Sent, Paid, Collections)"}
      ]
    }
  ]
}
